{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "ZhiYiQuant",
  "version": "2.2.0",
  "identifier": "com.zhiyiquant.desktop",
  "build": {
    "frontendDist": "../quantdinger_vue/dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "npm --prefix ./quantdinger_vue run serve",
    "beforeBuildCommand": "npm --prefix ./quantdinger_vue run build"
  },
  "app": {
    "windows": [
      {
        "title": "ZhiYiQuant",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/quantdinger-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
