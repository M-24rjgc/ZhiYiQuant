{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "智弈量化",
  "version": "1.0.1",
  "identifier": "com.zhiyiquant.desktop",
  "build": {
    "frontendDist": "../zhiyiquant_vue/dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "npm --prefix ./zhiyiquant_vue run serve",
    "beforeBuildCommand": "npm --prefix ./zhiyiquant_vue run build"
  },
  "app": {
    "windows": [
      {
        "title": "智弈量化",
        "width": 1360,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "externalBin": [
      "binaries/zhiyiquant-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
